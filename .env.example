# Copy to backend/.env and fill in. Defaults run fully offline with the mock LLM.

# ----- LLM provider -----
# Options: mock | openai | anthropic | gemini
LLM_PROVIDER=mock

# Used only when LLM_PROVIDER != mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Google Gemini (via its OpenAI-compatible endpoint; key from Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Llama (served via an OpenAI-compatible endpoint, e.g. vLLM / Ollama)
# Set LLM_PROVIDER=openai and point the base URL here for the ablation arm.
OPENAI_BASE_URL=

# ----- Database -----
# Default: local SQLite (no setup). For the paper/event-log runs use Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/stemgen
DATABASE_URL=sqlite:///./stemgen.db

# ----- Verifier thresholds -----
SEMANTIC_AMBIGUITY_THRESHOLD=0.5
MAX_REGENERATIONS=5
# Allowed difficulty-bin gap |observed - target|. 0 = exact match (strict; use
# for the formal experiment). 1 = forgiving (recommended for demos / weak models).
DIFFICULTY_TOLERANCE=0

# ----- Assessor (student model) tuning -----
ASSESSOR_ALPHA=0.4              # EMA weight on the newest attempt (0..1)
INITIAL_MASTERY=0.2            # cold-start mastery prior per skill
MISCONCEPTION_THRESHOLD=0.25   # mastery below this is flagged as a gap

# ----- Difficulty scoring anchors (advanced; JSON) -----
# Per-skill (lo, hi) raw-score range that difficulty is binned 1..5 against.
# DIFFICULTY_MATH_ANCHORS='{"derivative":[3,14],"integral":[3,9],"limit":[6.5,11],"solve_equation":[2.5,6],"simplify":[1,13.5]}'
# DIFFICULTY_PHYS_ANCHORS='{"kinematics":[2,4.5],"newton_friction":[3.5,6],"work_energy":[2.5,5],"impulse_momentum":[2,4.5],"circular_motion":[3.5,6.5]}'
# DIFFICULTY_PHYS_BASE='{"kinematics":1,"impulse_momentum":1.5,"work_energy":2,"newton_friction":2.5,"circular_motion":3}'
